#!/bin/bash
# Bu script uygulama guncellemelerinde bagimliliklari yeniler ve servisleri yeniden baslatir.

set -eu

APP="esp32-monitor"
INSTALL_DIR="/var/www/${APP}"
NODE_DIR="${INSTALL_DIR}/node-api"
ML_DIR="${INSTALL_DIR}/ml-service"
PY_VENV="${ML_DIR}/.venv"

cp -r /var/cache/yunohost/app_tmp/* "${INSTALL_DIR}/"

cd "${NODE_DIR}"
npm install --omit=dev

cd "${ML_DIR}"
if [ ! -d "${PY_VENV}" ]; then
  python3 -m venv "${PY_VENV}"
fi
"${PY_VENV}/bin/pip" install --upgrade pip
"${PY_VENV}/bin/pip" install -r requirements.txt

systemctl daemon-reload
systemctl restart "${APP}-node.service" "${APP}-ml.service"
nginx -t && systemctl reload nginx
