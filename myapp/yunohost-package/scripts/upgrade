#!/bin/bash
# Bu script uygulama guncellemelerinde bagimliliklari yeniler ve servisleri yeniden baslatir.

set -eu

APP="esp32-monitor"
INSTALL_DIR="/var/www/${APP}"
NODE_DIR="${INSTALL_DIR}/node-api"
ML_DIR="${INSTALL_DIR}/ml-service"
PY_VENV="${ML_DIR}/.venv"
APP_SRC_DIR="${YNH_APP_BASEDIR:-/var/cache/yunohost/app_tmp}"

if [ -d "${APP_SRC_DIR}/myapp/node-api" ] && [ -d "${APP_SRC_DIR}/myapp/ml-service" ]; then
  rm -rf "${INSTALL_DIR}/node-api" "${INSTALL_DIR}/ml-service"
  cp -r "${APP_SRC_DIR}/myapp/node-api" "${INSTALL_DIR}/node-api"
  cp -r "${APP_SRC_DIR}/myapp/ml-service" "${INSTALL_DIR}/ml-service"
elif [ -d "${APP_SRC_DIR}/node-api" ] && [ -d "${APP_SRC_DIR}/ml-service" ]; then
  rm -rf "${INSTALL_DIR}/node-api" "${INSTALL_DIR}/ml-service"
  cp -r "${APP_SRC_DIR}/node-api" "${INSTALL_DIR}/node-api"
  cp -r "${APP_SRC_DIR}/ml-service" "${INSTALL_DIR}/ml-service"
else
  echo "HATA: node-api ve ml-service klasorleri bulunamadi. APP_SRC_DIR=${APP_SRC_DIR}"
  exit 1
fi

cd "${NODE_DIR}"
npm install --omit=dev

cd "${ML_DIR}"
if [ ! -d "${PY_VENV}" ]; then
  python3 -m venv "${PY_VENV}"
fi
"${PY_VENV}/bin/pip" install --upgrade pip
"${PY_VENV}/bin/pip" install -r requirements.txt

systemctl daemon-reload
systemctl restart "${APP}-node.service" "${APP}-ml.service"
nginx -t && systemctl reload nginx
